# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT - EXAMPLE
# =============================================================================
# Copy this file to .env.local and fill in the values

# NextAuth.js / Auth.js Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your-secret-here
NEXTAUTH_SECRET=your-secret-here

# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# Database Configuration
# Local: postgresql://postgres:postgres@localhost:5433/startupinvestments
# Azure: postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# API Key for backend authentication (server-side only, do NOT prefix with NEXT_PUBLIC_)
# Generate with: openssl rand -hex 32
API_KEY=

# Feature Flags
NEXT_PUBLIC_AUTH_ENABLED=true

# Daily News Digest configuration (used by ingest/digest workflows and APIs)
RESEND_API_KEY=
NEWS_DIGEST_FROM_EMAIL=onboarding@resend.dev
NEWS_DIGEST_REPLY_TO=
PUBLIC_BASE_URL=https://buildatlas.net

# News LLM enrichment
NEWS_LLM_ENRICHMENT=false
NEWS_LLM_CONCURRENCY=4
NEWS_LLM_MODEL=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o
