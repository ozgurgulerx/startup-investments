# =============================================================================
# Local Development Environment
# Copy this file to .env.local and update values as needed
# =============================================================================

# Database (local Docker PostgreSQL on port 5433 to avoid conflicts)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/startupinvestments

# API Configuration
API_PORT=3001
API_URL=http://localhost:3001

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# OpenAI (for analysis features)
OPENAI_API_KEY=your-openai-key-here

# Daily News Digest
RESEND_API_KEY=your-resend-key
NEWS_DIGEST_FROM_EMAIL=onboarding@resend.dev
NEWS_DIGEST_REPLY_TO=
PUBLIC_BASE_URL=https://buildatlas.net

# News LLM Enrichment
NEWS_LLM_ENRICHMENT=false
NEWS_LLM_CONCURRENCY=4
NEWS_LLM_MODEL=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Optional: Azure Storage (for production data sync)
# AZURE_STORAGE_CONNECTION_STRING=

# Development flags
NODE_ENV=development
