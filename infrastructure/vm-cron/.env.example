# BuildAtlas VM Cron — Environment Variables
# Copy to /etc/buildatlas/.env and fill in values.
# chmod 600 /etc/buildatlas/.env

# === Database ===
DATABASE_URL=postgresql://user:pass@aistartupstr.postgres.database.azure.com:5432/startupinvestments?sslmode=require

# === Azure Infrastructure ===
AKS_CLUSTER_NAME=aks-aistartuptr
AKS_RESOURCE_GROUP=aistartuptr
POSTGRES_SERVER_NAME=aistartupstr
POSTGRES_RESOURCE_GROUP=aistartupstr
API_URL=https://startupapi-f7gfbpbtbtfqdmdv.b02.azurefd.net

# === Azure Storage (for blob sync) ===
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=buildatlasstorage;...

# === News Ingest ===
OPENAI_API_KEY=sk-...
PRODUCT_HUNT_TOKEN=
NEWS_API_KEY=
GNEWS_API_KEY=
NEWS_LLM_ENRICHMENT=true
NEWS_LLM_MAX_CLUSTERS=24
NEWS_LLM_CONCURRENCY=4
NEWS_LLM_MODEL=gpt-4o-mini

# === Crawl Frontier ===
BROWSERLESS_ENDPOINT=wss://...
BROWSERLESS_TOKEN=
CRAWLER_RUNTIME=scrapy
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_UNBLOCK_MODE=auto
CRAWLER_UNBLOCK_PROVIDER=browserless
CRAWLER_RAW_CAPTURE_ENABLED=true
CRAWLER_RAW_CAPTURE_RETENTION_DAYS=90

# === News Digest (Resend email) ===
RESEND_API_KEY=re_...
NEWS_DIGEST_REPLY_TO=
NEWS_DIGEST_FROM_EMAIL=Build Atlas <news@buildatlas.net>
PUBLIC_BASE_URL=https://buildatlas.net

# === Backend Deploy (K8s secrets) ===
API_KEY=
ADMIN_KEY=
FRONT_DOOR_ID=
REDIS_URL=

# === Frontend Build & Deploy ===
NEXT_PUBLIC_API_URL=https://startupapi-f7gfbpbtbtfqdmdv.b02.azurefd.net
NEXTAUTH_URL=https://buildatlas.net
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
POSTHOG_KEY=

# === Slack ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# === GitHub (for daily summary) ===
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=ozgurgulerx/startup-investments
