# BuildAtlas VM Cron — Environment Variables
# Copy to /etc/buildatlas/.env and fill in values.
# chmod 600 /etc/buildatlas/.env

# === Database ===
DATABASE_URL=postgresql://user:pass@aistartupstr.postgres.database.azure.com:5432/startupinvestments?sslmode=require

# === Azure Infrastructure ===
AKS_CLUSTER_NAME=aks-aistartuptr
AKS_RESOURCE_GROUP=aistartuptr
POSTGRES_SERVER_NAME=aistartupstr
POSTGRES_RESOURCE_GROUP=aistartupstr
API_URL=https://startupapi-f7gfbpbtbtfqdmdv.b02.azurefd.net

# === Azure Functions Deploy (VM fallback) ===
AZURE_FUNCTIONAPP_NAME=buildatlas-functions
AZURE_FUNCTIONS_RESOURCE_GROUP=aistartuptr
# Optional override for health checks:
# FUNCTIONS_BASE_URL=https://buildatlas-functions.azurewebsites.net

# === Azure Storage (for blob sync) ===
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=buildatlasstorage;...

# === Azure OpenAI (managed identity auth — no API key needed) ===
# The VM's system-assigned managed identity has "Cognitive Services OpenAI User" role.
AZURE_OPENAI_ENDPOINT=https://aoai-ep-swedencentral02.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-nano
# AZURE_OPENAI_API_VERSION=2024-06-01
#
# Embedding model (for vector search):
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
#
# Daily brief model (optional — falls back to AZURE_OPENAI_DEPLOYMENT_NAME):
# AZURE_OPENAI_DAILY_BRIEF_DEPLOYMENT_NAME=gpt-5-mini
# AZURE_OPENAI_DAILY_BRIEF_EFFORT=low

# === News Ingest ===
OPENAI_API_KEY=sk-...
PRODUCT_HUNT_TOKEN=
NEWS_API_KEY=
GNEWS_API_KEY=
# GitHub "trending-like" AI repos (Search API; no scraping). Optional token increases rate limits.
# GITHUB_TOKEN=
# GITHUB_TRENDING_TOPICS=artificial-intelligence,llm,generative-ai
# GITHUB_TRENDING_CREATED_DAYS=30
# GITHUB_TRENDING_MIN_STARS=50
# GITHUB_TRENDING_LIMIT=30
# GITHUB_TRENDING_MIN_STAR_DELTA=50
#
# Amazon "New Releases" AI books (Playwright scrape). Disabled unless URLs are provided.
# (Browse nodes: AI & Machine Learning=3887, Natural Language Processing=271581011, Computer Vision & Pattern Recognition=132552011)
# AMAZON_NEW_RELEASES_URLS=https://www.amazon.com/gp/new-releases/books/3887,https://www.amazon.com/gp/new-releases/books/271581011,https://www.amazon.com/gp/new-releases/books/132552011
# AMAZON_NEW_RELEASES_MAX_ITEMS=30
# AMAZON_NEW_RELEASES_MIN_RANK_DELTA=10
# AMAZON_PLAYWRIGHT_TIMEOUT_MS=20000
NEWS_LLM_ENRICHMENT=true
NEWS_LLM_MAX_CLUSTERS=200
NEWS_LLM_CONCURRENCY=8
NEWS_LLM_MODEL=gpt-5-nano
# Enable intel-first title/bullets generation for news cards.
# Strict mode: ingest rejects intel fields when model does not prove all cluster sources were reviewed.
INTEL_FIRST_PROMPT=true

# === X/Twitter Trend Ingest ===
X_TRENDS_ENABLED=true
X_API_BEARER_TOKEN=
# Optional JSON string or path to JSON file: {"global":[...], "turkey":[...]}
# X_TRENDS_QUERY_PACK=
X_TRENDS_MAX_QUERIES_PER_RUN=4
X_TRENDS_MAX_PAGES_PER_QUERY=2
X_TRENDS_PAGE_SIZE=50
X_TRENDS_LOOKBACK_HOURS=24

# === X/Twitter Auto Posting ===
# OAuth1 user-context credentials for POST /2/tweets
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_POSTING_ENABLED=false
X_MAX_POSTS_PER_DAY=3
X_MIN_POST_INTERVAL_MINUTES=120
X_POST_MAX_ATTEMPTS=3
X_POST_DEDUPE_DAYS=7
X_POST_GENERATE_REGION=all
X_POST_GENERATE_MAX_ITEMS=6
X_POST_PUBLISH_MAX_ITEMS=5
X_POST_METRICS_DAYS_BACK=7
X_POST_METRICS_MAX_POSTS=100

# === Event Processor / Startup Onboarding ===
# Minimum event confidence to consider deep research enqueue
DEEP_RESEARCH_MIN_EVENT_CONFIDENCE=0.55
# For stubs, require crawl success rate above this threshold when available
DEEP_RESEARCH_MIN_CRAWL_SUCCESS_RATE=0.20
EVENT_PROCESSOR_BATCH_SIZE=100

# === Deep Research Consumer (conservative caps) ===
DEEP_RESEARCH_ENABLED=true
DEEP_RESEARCH_BATCH_SIZE=8
DEEP_RESEARCH_MAX_CONCURRENT=3
DEEP_RESEARCH_MAX_ITEMS_PER_RUN=8
DEEP_RESEARCH_MAX_DAILY_USD=15
DEEP_RESEARCH_MAX_MONTHLY_USD=300

# === Onboarding Trace Alerts ===
ONBOARDING_ALERTS_ENABLED=true
ONBOARDING_ALERTS_BATCH_SIZE=25

# === Crawl Frontier ===
# Unblock provider: "stealth" (local Playwright) or "browserless" (remote API)
CRAWLER_UNBLOCK_PROVIDER=stealth
CRAWLER_RUNTIME=scrapy
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_UNBLOCK_MODE=auto
CRAWLER_RAW_CAPTURE_ENABLED=true
CRAWLER_RAW_CAPTURE_RETENTION_DAYS=90
CRAWLER_FRONTIER_BATCH_SIZE=50
# Frontier seeding strategy (reliability-first; worker runs every 30m, broad seed every N hours)
CRAWL_FRONTIER_SEED_ENABLED=true
CRAWL_FRONTIER_SEED_INTERVAL_HOURS=6
CRAWL_FRONTIER_SEED_LIMIT=5000
CRAWL_FRONTIER_SEED_MAX_STARTUPS=500
CRAWL_FRONTIER_SEED_MAX_SECONDS=600
CRAWL_FRONTIER_SEED_TIMEOUT_MIN=20
# Optional: force a seed chunk on next run, then set back to false
# CRAWL_FRONTIER_FORCE_SEED=false
# Browserless (only needed if CRAWLER_UNBLOCK_PROVIDER=browserless)
# BROWSERLESS_ENDPOINT=wss://...
# BROWSERLESS_TOKEN=

# === News Digest (Resend email) ===
RESEND_API_KEY=re_...
NEWS_DIGEST_REPLY_TO=
NEWS_DIGEST_FROM_EMAIL=Build Atlas <news@buildatlas.net>
PUBLIC_BASE_URL=https://buildatlas.net

# === Daily Metrics Report Email (best-effort) ===
# Comma-separated recipients for daily ops summary email.
# Example: METRICS_REPORT_EMAIL_TO=343544@gmail.com,ops@example.com
METRICS_REPORT_EMAIL_TO=
# Optional sender (defaults to NEWS_DIGEST_FROM_EMAIL)
METRICS_REPORT_EMAIL_FROM=
# Optional subject prefix (example: "[BuildAtlas] ")
METRICS_REPORT_EMAIL_SUBJECT_PREFIX=

# === Backend Deploy (K8s secrets) ===
API_KEY=
ADMIN_KEY=
FRONT_DOOR_ID=
REDIS_URL=

# === Frontend Build & Deploy ===
NEXT_PUBLIC_API_URL=https://startupapi-f7gfbpbtbtfqdmdv.b02.azurefd.net
NEXTAUTH_URL=https://buildatlas.net
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
POSTHOG_KEY=
# Low-cost analytics defaults (public, non-secret client config)
POSTHOG_AUTOCAPTURE=false
POSTHOG_CAPTURE_PAGELEAVE=false
POSTHOG_CAPTURE_DEAD_CLICKS=false
POSTHOG_CAPTURE_EXCEPTIONS=true
POSTHOG_REPLAY_SAMPLE_RATE=0.03
# Optional: Microsoft Clarity heatmaps/session replay (free tier)
CLARITY_PROJECT_ID=

# === Application Insights (API telemetry) ===
APPLICATIONINSIGHTS_CONNECTION_STRING=

# === Slack ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional: send success notifications for selected jobs.
# - Default (when unset): news-ingest,news-digest,frontend-deploy,backend-deploy,code-update,sync-data,crawl-frontier
# - Use "all" to notify for every cron job (not recommended).
# - Use "none" (or "off") to disable success notifications entirely.
# Examples:
#   SLACK_NOTIFY_SUCCESS_JOBS=news-ingest,news-digest
#   SLACK_NOTIFY_SUCCESS_JOBS=all
#   SLACK_NOTIFY_SUCCESS_JOBS=none
# SLACK_NOTIFY_SUCCESS_JOBS=
# Optional: start notifications for selected jobs.
# - Default: frontend-deploy,backend-deploy,sync-data,code-update,news-digest
# - Use "all" to notify starts for every job.
# - Use "none" (or "off") to disable start notifications.
# SLACK_NOTIFY_START_JOBS=

# === GitHub (for daily summary) ===
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=ozgurgulerx/startup-investments

# === Release Reconciler ===
# Compares desired origin/main SHA with public web/api live SHAs.
# RELEASE_RECONCILE_BRANCH=main
# RELEASE_RECONCILE_FRONTEND_URL=https://buildatlas.net
# RELEASE_RECONCILE_API_HEALTH_URL=https://startupapi-f7gfbpbtbtfqdmdv.b02.azurefd.net/health
# RELEASE_RECONCILE_ALERT_AFTER_MINUTES=20
# RELEASE_RECONCILE_REMINDER_MINUTES=60
