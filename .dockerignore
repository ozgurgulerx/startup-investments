# .dockerignore — Used by both apps/web/Dockerfile and apps/api/Dockerfile
# (both use repo root as build context).
#
# Whitelist approach: deny everything, then allow what the builds need.

# Deny all
*

# Root config files needed by pnpm workspace
!package.json
!pnpm-workspace.yaml
!pnpm-lock.yaml
!turbo.json

# Web app source + data
!apps/web/

# API app source
!apps/api/

# Shared workspace package
!packages/shared/

# Analysis package (for analysis Dockerfile)
!packages/analysis/

# Ops + pipeline automation (AKS CronJobs, shared migration runner, Slack notify, etc.)
!scripts/
!database/migrations/
!infrastructure/ops/
!infrastructure/pipelines/
!infrastructure/vm-cron/
!infrastructure/kubernetes/

# Re-exclude build artifacts and large/sensitive files
apps/web/.next/
apps/web/node_modules/
apps/web/.env*
apps/web/deploy/
apps/web/deploy.zip
apps/api/node_modules/
apps/api/dist/
apps/api/.env*
packages/shared/node_modules/

# Exclude raw_content (crawled HTML, ~58MB) — not needed at runtime
apps/web/data/**/raw_content/

# Analysis package exclusions
packages/analysis/venv/
packages/analysis/data/crawl_cache/
packages/analysis/__pycache__/
packages/analysis/**/__pycache__/
packages/analysis/.pytest_cache/
