# =============================================================================
# AI Startup Intelligence Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env files with real values

# =============================================================================
# Azure OpenAI (for analysis)
# =============================================================================
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# =============================================================================
# Anthropic (for AI chat in web app)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-key

# =============================================================================
# Data paths (optional - defaults provided)
# =============================================================================
# DATA_PATH=./data
# CURRENT_PERIOD=2026-01

# =============================================================================
# Web App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Daily News Digest + News LLM Enrichment
# =============================================================================
RESEND_API_KEY=your-resend-key
NEWS_DIGEST_FROM_EMAIL=onboarding@resend.dev
NEWS_DIGEST_REPLY_TO=
PUBLIC_BASE_URL=https://buildatlas.net
NEWS_LLM_ENRICHMENT=false
NEWS_LLM_CONCURRENCY=4
NEWS_LLM_MODEL=gpt-4o-mini

# =============================================================================
# Crawler Runtime (Frontier + Unblock + Raw Capture)
# =============================================================================
CRAWLER_RUNTIME=scrapy
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_UNBLOCK_MODE=auto
CRAWLER_UNBLOCK_PROVIDER=stealth
# Browserless (only needed if CRAWLER_UNBLOCK_PROVIDER=browserless)
# BROWSERLESS_ENDPOINT=
# BROWSERLESS_TOKEN=
CRAWLER_AI_BLOCKING_ASSUMED=true
CRAWLER_RAW_CAPTURE_ENABLED=true
CRAWLER_RAW_CAPTURE_RETENTION_DAYS=90
CRAWLER_RAW_CAPTURE_MAX_BODY_BYTES=1048576
CRAWLER_FEED_DISCOVERY_ENABLED=true
CRAWLER_FEED_DISCOVERY_MAX_URLS=20
